# macOS
.DS_Store
.AppleDouble
.LSOverride

# Xcode user data (never commit these)
xcuserdata/
*.xcuserstate
*.xccheckout
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# Build output
build/
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
# Keep Package.resolved for reproducible builds
# !TinyGlow.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

# CocoaPods (not used, but just in case)
Pods/
Podfile.lock

# Carthage (not used)
Carthage/Build/

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Firebase — contains API keys, never commit
GoogleService-Info.plist

# Xcode Playground
playground.xcworkspace
timeline.xctimeline

# Simulator
*.xcplayground
